# API base URL — leave empty to use relative /api path (proxied in dev, or same-origin in prod)
# Set to your Cloudflare Worker URL for production
VITE_API_BASE_URL=

# GitHub Models LLM (optional model override)
# Token is now entered by each user via the UI — NOT stored in env vars
VITE_GITHUB_LLM_MODEL=gpt-4o-mini
